{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wrc/job-apply-button",
  "title": "Apply Button",
  "category": "jobplace-jobs",
  "textdomain": "jobplace",
  "ancestor": [
    "wrc/jobs-template",
    "wrc/job-page"
  ],
  "attributes": {
    "text": {
      "type": "string",
      "default": "Apply now"
    },
    "buttonStyle": {
      "type": "string",
      "default": "is-style-fill"
    },
    "openInNewTab": {
      "type": "boolean",
      "default": true
    }
  },
  "usesContext": [
    "job"
  ],
  "supports": {
    "interactivity": true,
    "html": false,
    "typography": {
      "fontSize": true,
      "lineHeight": true
    },
    "color": {
      "text": true,
      "background": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "render": "file:./view.php",
  "editorScript": "file:./index.js",
  "style": [
    "jobplace-jobs-board",
    "file:./style-index.css"
  ]
}
