{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wrc/jobs-template",
	"title": "Job Template",
	"description": "Template for a single job in the list.",
	"category": "jobplace-jobs",
	"textdomain": "jobplace",
	"ancestor": ["wrc/jobs-list"],
	"usesContext": ["query"],
	"supports": {
		"interactivity": true,
		"html": false,
		"layout": true,
		"color": {
			"text": true,
			"background": true,
			"gradients": true,
			"link": true,
			"__experimentalDefaultControls": {
				"background": true,
				"text": true
			}
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true
		},
		"__experimentalBorder": {
			"radius": true,
			"color": true,
			"width": true,
			"style": true
		}
	},
	"render": "file:./view.php",
	"editorScript": "file:./index.js",
	"style": ["jobplace-jobs-board", "file:./style-index.css"],
	"viewScriptModule": ["@jobplace/jobs"]
}
