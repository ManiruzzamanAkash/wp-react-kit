{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wrc/jobs-list",
	"title": "Jobs List",
	"description": "Display an interactive board of job listings.",
	"category": "jobplace-jobs",
	"textdomain": "jobplace",
	"icon": "businessperson",
	"keywords": ["job", "jobs", "careers", "listings", "board", "hiring"],
	"attributes": {
		"query": {
			"type": "object",
			"default": {
				"perPage": 10,
				"page": 1,
				"orderby": "id",
				"order": "desc",
				"search": "",
				"status": "published"
			}
		}
	},
	"providesContext": {
		"query": "query"
	},
	"supports": {
		"interactivity": true,
		"html": false,
		"align": ["wide", "full"],
		"layout": true,
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true
		}
	},
	"render": "file:./view.php",
	"editorScript": "file:./index.js",
	"style": ["jobplace-jobs-board", "file:./style-index.css"],
	"viewScript": ["wp-url", "wp-api-fetch", "wp-i18n"],
	"viewScriptModule": ["@jobplace/jobs"]
}
